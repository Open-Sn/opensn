#!/usr/bin/env python3
"""
OpenSn Test system

Principles:
- A test is specified by an input file
- A test can be subjected to one or more checks
  - RunCheck: Does it run and exit with error-code 0
  - ConsoleOutputCheck: Does the console output contain specific text
  - ConsoleGoldCheck: Diff a portion of the console output against gold output
  - OutputCheck: Compares output data (vtk, exodus, data) against gold output
- Any folder that contains the correct information for tests, can be
  bootstrapped to the test system.
- A folder can be used as a staging area to perfect a test after which the
  test can be moved into the appropriate place
"""
import os
import sys
import argparse
import glob
import textwrap
import warnings
from datetime import datetime

from src import job_manager

if sys.version_info.major < 3:
    raise Exception("Found Python version " + str(sys.version_info.major) + "."
                    + str(sys.version_info.minor) + " but version >=3 required.")


def ParseVerbosity(value):
    """Parse optional -v/--verbose values while preserving legacy -v 1 usage."""
    if value is None:
        return True
    if isinstance(value, bool):
        return value

    normalized = str(value).strip().lower()
    if normalized in ("", "true", "yes", "on"):
        return True
    if normalized in ("false", "no", "off"):
        return False

    try:
        return int(normalized) != 0
    except ValueError as exc:
        raise argparse.ArgumentTypeError(
            "--verbose expects an optional integer or boolean value"
        ) from exc

# Process commandline arguments
arguments_help = textwrap.dedent('''\
Run the test suite or, optionally, a series of individual tests or a range of tests.
''')

parser = argparse.ArgumentParser(
    description="A script to run the regression test suite.",
    epilog=arguments_help
)

parser.add_argument(
    "-d", "--directory",
    type=str, required=False,
    default=os.path.abspath(os.path.dirname(__file__)),
    help="The directory to search for test files"
)

parser.add_argument(
    "-t", "--test",
    type=str, nargs="+", required=False, default=None,
    help="Full path, filename, or wildcard pattern for one or more OpenSn test files"
)

parser.add_argument(
    "--exe",
    type=str, required=False,
    help="The executable to use for testing"
)

parser.add_argument(
    "-j", "--jobs",
    type=int, required=False, default=0,
    help="Allow up to N CPU slots at once. CPU slots account for MPI ranks multiplied by "
         "OPENSN_NUM_THREADS."
)

parser.add_argument(
    "-v", "--verbose",
    nargs="?",
    const=True,
    default=False,
    type=ParseVerbosity,
    help="Print verbose check failure details. Accepts legacy forms such as -v 1 or -v 0."
)

parser.add_argument(
    "--mpi-cmd",
    type=str, required=False, default="mpiexec -n ",
    help="MPI application launcher command"
)

parser.add_argument(
    "--engine",
    type=str,
    choices=["console", "module", "jupyter"],
    default="console",
    help="Choose execution mode (console, jupyter)."
)

parser.add_argument(
    "--gpu",
    action="store_true",
    help="Run tests that require a GPU."
)

parser.add_argument(
    "--gpu-jobs",
    type=int,
    required=False,
    default=0,
    help="Allow up to N concurrent GPU tests. Defaults to auto-detection and falls back to 1."
)

parser.add_argument(
    "-w", "--weights",
    type=int, required=False, default=3,
    help="Test weight. Single numeric value < 7. This number, when converted to binary, specifies "
         "the long, intermediate, and short test weight configuration. For example: A value of 7, "
         "or 111 in binary [long, intermediate, short], runs the long, intermediate and short "
         "tests. A value of 4, or 100 in binary, runs only the long tests. A value of 3, or 011, "
         "uns the short and intermediate tests."
)

parser.add_argument(
    "--run-log",
    type=str,
    required=False,
    default=None,
    help="Write concatenated per-test output to file. "
         "Default: run_tests_YYYYmmdd_HHMMSS.log"
)

parser.add_argument(
    "--show-filtered",
    action="store_true",
    help="Print tests filtered out by -t/--test selection."
)

parser.add_argument(
    "--slowest",
    type=int,
    default=10,
    help="Print the N slowest tests in the final summary. Use 0 to suppress."
)

argv = parser.parse_args()

def PrepareTestSelection(argv):
    """Resolve -t/--test paths and wildcards into selectors relative to argv.directory."""
    if argv.test is None:
        return

    selected_paths = []
    selected_names = []

    for selector in argv.test:
        matches = sorted(glob.glob(selector)) if glob.has_magic(selector) else []
        if matches:
            selected_paths.extend(matches)
        elif glob.has_magic(selector):
            raise FileNotFoundError("No tests match pattern: " + selector)
        elif os.path.dirname(selector) != "":
            selected_paths.append(selector)
        else:
            selected_names.append(selector)

    if selected_paths:
        abs_paths = [os.path.abspath(path) for path in selected_paths]
        common_path = os.path.commonpath(
            [path if os.path.isdir(path) else os.path.dirname(path) for path in abs_paths]
        )
        argv.directory = common_path
        selected_names.extend(os.path.relpath(path, argv.directory) for path in abs_paths)

    argv.test = selected_names


if argv.test is not None:
    PrepareTestSelection(argv)

# Check the test directory exists
if not os.path.isdir(argv.directory):
    raise NotADirectoryError(argv.directory)

# Setup run log capture
if argv.run_log is None:
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    argv.run_log = os.path.join(argv.directory, f"run_tests_{timestamp}.log")


def WriteAggregatedRunLog(tests, run_log_path: str, base_directory: str):
    """Write a single file with concatenated contents of each test *.out."""
    run_log_abs = os.path.abspath(run_log_path)
    run_log_dir = os.path.dirname(run_log_abs)
    if run_log_dir != "":
        os.makedirs(run_log_dir, exist_ok=True)

    with open(run_log_abs, "w", encoding="utf-8") as log_file:
        log_file.write("# OpenSn aggregated per-test outputs\n")
        log_file.write(f"# Generated: {datetime.now().isoformat(timespec='seconds')}\n")
        log_file.write(f"# Base directory: {os.path.abspath(base_directory)}\n\n")

        for test in tests:
            test_path = os.path.join(test.file_dir, test.filename)
            rel_test_path = os.path.relpath(test_path, base_directory)
            test_out = os.path.join(test.file_dir, "out", f"{test.GetOutFilenamePrefix()}.out")

            log_file.write("=" * 120 + "\n")
            log_file.write(f"TEST: {rel_test_path}\n")
            log_file.write(f"MPI_PROCS: {test.num_procs}\n")
            if test.args:
                log_file.write("ARGS: " + " ".join(test.args) + "\n")
            if test.annotations:
                log_file.write("ANNOTATIONS:\n")
                for ann in test.annotations:
                    log_file.write(f"  - {ann}\n")
            if hasattr(test, "check_results") and test.check_results:
                log_file.write("CHECK_RESULTS:\n")
                for result in test.check_results:
                    status = "PASSED" if result["passed"] else "FAILED"
                    summary = result["summary"] if result["summary"] else "<no summary>"
                    log_file.write(f"  - {status}: {summary}\n")
            log_file.write("-" * 120 + "\n")

            if os.path.exists(test_out):
                with open(test_out, "r", encoding="utf-8") as test_file:
                    content = test_file.read()
                log_file.write(content)
                if not content.endswith("\n"):
                    log_file.write("\n")
            else:
                log_file.write(f"[No output file found at {test_out}]\n")

            log_file.write("\n")

# Check the exe exists
if argv.exe is None:
    argv.exe = "build/python/opensn"
if not os.path.isfile(argv.exe):
    raise FileNotFoundError(argv.exe)

# Ensure exe path is absolute
argv.exe = os.path.abspath(argv.exe)

# If no test directory specified then we print help and quit
if argv.directory is None:
    print(arguments_help)
    sys.exit(0)

# Execute
test_hierarchy = job_manager.BuildSearchHierarchyForTests(argv)
with warnings.catch_warnings(record=True) as warning_manager1:
    tests = job_manager.ConfigureTests(test_hierarchy, argv)

job_manager.PrintCaughtWarnings(warning_manager1, "Warnings during test configuration")
if len(warning_manager1) > 0:
    sys.exit(-1)

print("""
********************************** OpenSn Test system **********************************

Use -h to print argument options.""")

if argv.verbose:
    print()
    print("Test directories found:")
    for test_dir in test_hierarchy:
        print("  " + test_dir)

print()
print("Output format:")
print("  \033[33m[NP]\033[0m <relative test path> "
      "\033[32mPassed\033[0m/\033[31mFailed\033[0m "
      "<elapsed time> [annotations]")
print("  \033[33m[NP]\033[0m is the number of MPI processes requested by the test.")
print("  Annotations identify skip reasons, missing files, and check failures.")
print("  Elapsed time is OpenSn-reported runtime when available, otherwise wall time.")
print("  Use -v for detailed check diagnostics.")

print()

job_manager.PrintCaughtWarnings(warning_manager1, "Warnings during test configuration")
print()

with warnings.catch_warnings(record=True) as warning_manager2:
    retval = job_manager.RunTests(tests, argv)

job_manager.PrintCaughtWarnings(warning_manager2, "Warnings during test execution")
WriteAggregatedRunLog(tests, argv.run_log, argv.directory)

sys.exit(retval)
